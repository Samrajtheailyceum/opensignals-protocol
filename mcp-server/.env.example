# OpenSignals Protocol MCP Server Environment Variables

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
OPENSIGNALS_LOG_LEVEL=INFO

# Optional: Path to OpenSignals Protocol repository root
# If not set, will use parent directory of mcp-server
# OPENSIGNALS_REPO_ROOT=/path/to/opensignals-protocol

# Optional: Custom examples directory
# OPENSIGNALS_EXAMPLES_DIR=/path/to/examples

# Optional: Custom schemas directory
# OPENSIGNALS_SCHEMAS_DIR=/path/to/schemas

# Optional: Remote manifest base URL for fetching live manifests
# OPENSIGNALS_MANIFEST_BASE_URL=https://signals.example.com/.well-known/opensignals

# Optional: Enable remote manifest fetching (true/false)
# OPENSIGNALS_ENABLE_REMOTE_FETCH=false

# Optional: Cache duration for manifests in seconds
# OPENSIGNALS_CACHE_TTL=3600

# Optional: Audit log directory for persistent audit trails
# OPENSIGNALS_AUDIT_LOG_DIR=/var/log/opensignals

# Optional: Enable audit log persistence (true/false)
# OPENSIGNALS_ENABLE_AUDIT_PERSISTENCE=false
