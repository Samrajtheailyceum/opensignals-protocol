{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensignals.org/schemas/v0.1/trust-score.schema.json",
  "title": "Trust Score Schema",
  "description": "Schema for calculating and representing trust scores for OpenSignals Protocol signals. Trust scores provide a standardized way to evaluate signal quality, reliability, and trustworthiness across multiple dimensions.",
  "type": "object",
  "required": [
    "signal_id",
    "timestamp",
    "scores",
    "calculation_method",
    "version"
  ],
  "properties": {
    "signal_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "minLength": 3,
      "maxLength": 128,
      "description": "Unique identifier of the signal being scored. Must match the signal_id in the corresponding manifest."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this trust score was calculated."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
      "description": "Version of the trust scoring methodology used.",
      "examples": ["1.0", "1.0.0"]
    },
    "scores": {
      "type": "object",
      "required": [
        "coverage",
        "freshness",
        "precision",
        "stability",
        "explainability",
        "compliance",
        "overall"
      ],
      "properties": {
        "coverage": {
          "type": "object",
          "required": ["score", "details"],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Normalized score (0-1) for signal coverage. Measures the breadth and reach of the signal across the target population."
            },
            "details": {
              "type": "object",
              "properties": {
                "reach_percentage": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Percentage of target population covered by this signal."
                },
                "geographic_coverage": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^[A-Z]{2}$"
                  },
                  "description": "ISO 3166-1 alpha-2 country codes where signal has coverage."
                },
                "demographic_coverage": {
                  "type": "object",
                  "properties": {
                    "age_ranges": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Age ranges covered (e.g., ['18-24', '25-34'])."
                    },
                    "gender_distribution": {
                      "type": "object",
                      "description": "Distribution across gender categories."
                    }
                  },
                  "description": "Demographic dimensions of coverage."
                },
                "sample_size": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Total number of unique identifiers in the signal."
                }
              },
              "description": "Detailed breakdown of coverage metrics."
            }
          },
          "additionalProperties": false,
          "description": "Coverage dimension measuring signal reach and breadth."
        },
        "freshness": {
          "type": "object",
          "required": ["score", "details"],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Normalized score (0-1) for data freshness. Measures how current and up-to-date the signal data is."
            },
            "details": {
              "type": "object",
              "properties": {
                "average_age_hours": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Average age of data points in hours."
                },
                "last_updated": {
                  "type": "string",
                  "format": "date-time",
                  "description": "ISO 8601 timestamp of last data update."
                },
                "update_frequency": {
                  "type": "string",
                  "enum": [
                    "real_time",
                    "hourly",
                    "daily",
                    "weekly",
                    "monthly",
                    "on_demand"
                  ],
                  "description": "How frequently the signal is updated."
                },
                "staleness_percentage": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Percentage of data points considered stale based on update frequency."
                }
              },
              "description": "Detailed breakdown of freshness metrics."
            }
          },
          "additionalProperties": false,
          "description": "Freshness dimension measuring data currency and timeliness."
        },
        "precision": {
          "type": "object",
          "required": ["score", "details"],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Normalized score (0-1) for signal precision. Measures accuracy and correctness of signal classifications."
            },
            "details": {
              "type": "object",
              "properties": {
                "accuracy_rate": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Measured accuracy rate from validation studies."
                },
                "false_positive_rate": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Rate of incorrect positive classifications."
                },
                "false_negative_rate": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Rate of missed positive classifications."
                },
                "validation_method": {
                  "type": "string",
                  "enum": [
                    "ground_truth_comparison",
                    "survey_validation",
                    "panel_validation",
                    "deterministic_match",
                    "statistical_modeling",
                    "third_party_audit"
                  ],
                  "description": "Method used to validate precision."
                },
                "confidence_interval": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Statistical confidence level (e.g., 0.95 for 95%)."
                }
              },
              "description": "Detailed breakdown of precision metrics."
            }
          },
          "additionalProperties": false,
          "description": "Precision dimension measuring signal accuracy and correctness."
        },
        "stability": {
          "type": "object",
          "required": ["score", "details"],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Normalized score (0-1) for signal stability. Measures consistency and reliability over time."
            },
            "details": {
              "type": "object",
              "properties": {
                "uptime_percentage": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Service uptime percentage over measurement period."
                },
                "volatility_index": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Statistical measure of signal value volatility (lower is better)."
                },
                "consistency_rate": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Rate at which signal classifications remain consistent over time."
                },
                "measurement_period_days": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Number of days over which stability was measured."
                },
                "incident_count": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Number of service incidents or outages during measurement period."
                }
              },
              "description": "Detailed breakdown of stability metrics."
            }
          },
          "additionalProperties": false,
          "description": "Stability dimension measuring signal consistency and reliability."
        },
        "explainability": {
          "type": "object",
          "required": ["score", "details"],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Normalized score (0-1) for signal explainability. Measures transparency and interpretability of signal methodology."
            },
            "details": {
              "type": "object",
              "properties": {
                "methodology_transparency": {
                  "type": "string",
                  "enum": ["full", "partial", "limited", "proprietary"],
                  "description": "Level of methodology disclosure."
                },
                "data_lineage_available": {
                  "type": "boolean",
                  "description": "Whether complete data lineage is documented and accessible."
                },
                "algorithmic_details": {
                  "type": "string",
                  "enum": ["deterministic", "rules_based", "ml_explainable", "ml_black_box"],
                  "description": "Type and explainability of algorithms used."
                },
                "audit_trail_available": {
                  "type": "boolean",
                  "description": "Whether full audit trail is maintained and accessible."
                },
                "documentation_completeness": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Completeness score for signal documentation."
                }
              },
              "description": "Detailed breakdown of explainability metrics."
            }
          },
          "additionalProperties": false,
          "description": "Explainability dimension measuring transparency and interpretability."
        },
        "compliance": {
          "type": "object",
          "required": ["score", "details"],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Normalized score (0-1) for regulatory compliance. Measures adherence to privacy laws and industry standards."
            },
            "details": {
              "type": "object",
              "properties": {
                "certifications": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "gdpr_compliant",
                      "ccpa_compliant",
                      "cpra_compliant",
                      "lgpd_compliant",
                      "iso_27001",
                      "soc2_type2",
                      "privacy_shield",
                      "tag_certified"
                    ]
                  },
                  "description": "Active compliance certifications."
                },
                "consent_framework_support": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["tcf_v2", "tcf_v2.2", "gpp", "ccpa", "custom"]
                  },
                  "description": "Supported consent management frameworks."
                },
                "privacy_by_design": {
                  "type": "boolean",
                  "description": "Whether privacy-by-design principles are implemented."
                },
                "data_minimization": {
                  "type": "boolean",
                  "description": "Whether data minimization practices are followed."
                },
                "right_to_deletion_supported": {
                  "type": "boolean",
                  "description": "Whether user right to deletion is supported."
                },
                "last_audit_date": {
                  "type": "string",
                  "format": "date",
                  "description": "Date of most recent compliance audit."
                },
                "violations_count": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Number of compliance violations in the past year."
                }
              },
              "description": "Detailed breakdown of compliance metrics."
            }
          },
          "additionalProperties": false,
          "description": "Compliance dimension measuring regulatory adherence and privacy protection."
        },
        "overall": {
          "type": "object",
          "required": ["score", "calculation_method"],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Composite overall trust score (0-1) aggregating all dimensions. This is the primary trust indicator."
            },
            "calculation_method": {
              "type": "string",
              "enum": ["weighted_average", "geometric_mean", "harmonic_mean", "minimum", "custom"],
              "description": "Method used to aggregate individual dimension scores into overall score."
            },
            "weights": {
              "type": "object",
              "properties": {
                "coverage": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "freshness": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "precision": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "stability": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "explainability": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "compliance": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              },
              "description": "Weights used in weighted_average calculation (must sum to 1.0)."
            },
            "confidence_level": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Confidence level in the overall score calculation."
            }
          },
          "additionalProperties": false,
          "description": "Overall composite trust score aggregating all dimensions."
        }
      },
      "additionalProperties": false,
      "description": "Comprehensive trust scores across all evaluation dimensions."
    },
    "calculation_method": {
      "type": "object",
      "required": ["methodology", "data_sources"],
      "properties": {
        "methodology": {
          "type": "string",
          "minLength": 10,
          "maxLength": 2048,
          "description": "Detailed description of the methodology used to calculate trust scores."
        },
        "data_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "List of data sources used in score calculation."
        },
        "calculation_frequency": {
          "type": "string",
          "enum": ["real_time", "hourly", "daily", "weekly", "monthly", "on_demand"],
          "description": "How frequently trust scores are recalculated."
        },
        "automated": {
          "type": "boolean",
          "description": "Whether score calculation is fully automated or involves manual review."
        }
      },
      "additionalProperties": false,
      "description": "Information about how trust scores are calculated."
    },
    "historical_trends": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "overall_score"],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of historical score."
          },
          "overall_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Overall trust score at this point in time."
          },
          "dimension_scores": {
            "type": "object",
            "properties": {
              "coverage": {"type": "number", "minimum": 0, "maximum": 1},
              "freshness": {"type": "number", "minimum": 0, "maximum": 1},
              "precision": {"type": "number", "minimum": 0, "maximum": 1},
              "stability": {"type": "number", "minimum": 0, "maximum": 1},
              "explainability": {"type": "number", "minimum": 0, "maximum": 1},
              "compliance": {"type": "number", "minimum": 0, "maximum": 1}
            },
            "description": "Individual dimension scores at this point in time."
          }
        },
        "additionalProperties": false
      },
      "description": "Historical trust score data showing trends over time."
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "dimension", "message", "timestamp"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "info"],
            "description": "Severity level of the alert."
          },
          "dimension": {
            "type": "string",
            "enum": ["coverage", "freshness", "precision", "stability", "explainability", "compliance", "overall"],
            "description": "Trust dimension that triggered the alert."
          },
          "message": {
            "type": "string",
            "description": "Detailed alert message explaining the issue."
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when alert was triggered."
          },
          "threshold_violated": {
            "type": "number",
            "description": "Score threshold that was violated."
          },
          "recommended_action": {
            "type": "string",
            "description": "Recommended action to address the alert."
          }
        },
        "additionalProperties": false
      },
      "description": "Active alerts for trust score issues or threshold violations."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "scorer_id": {
          "type": "string",
          "description": "Identifier of the system or service that calculated this trust score."
        },
        "scorer_version": {
          "type": "string",
          "description": "Version of the scoring system used."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes or context about this trust score."
        }
      },
      "description": "Additional metadata about the trust score calculation."
    }
  },
  "additionalProperties": false
}
